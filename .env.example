# Environment variables for Drssed API
API_BASE_URL=http://localhost:8000
SECRET_TOKEN_KEY=SECRET_KEY_VALUE_FOR_JWT_AUTHENTICATION

# Database configuration
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_NAME=DATABASE_NAME
DATABASE_ROOT_PASSWORD=DATABASE_ROOT_PASSWORD
DATABASE_USERNAME=DATABASE_USERNAME
DATABASE_PASSWORD=DATABASE_PASSWORD

# Redis configuration for rate limiter
RATELIMITER_ENABLED=True
REDIS_URI=redis://redis:6379

# Scheduler configuration
DISABLE_SCHEDULER=False

CLEANUP_INACTIVE_DAYS=90
CLEANUP_MAX_DELETE=100

# Email configuration
EMAIL_ENABLED=False # Set to True to enable email sending
RESEND_API_KEY=RESEND_API_KEY_VALUE # Get this from Resend dashboard
EMAIL_FROM_ADDRESS=EMAIL_FROM_ADDRESS_VALUE
EMAIL_REPLY_TO=EMAIL_REPLY_TO_VALUE

# Flask configuration
FLASK_ENV=development # 'development' or 'production'
LOG_LEVEL=INFO